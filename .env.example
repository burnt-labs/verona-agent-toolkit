# Verona Agent Toolkit — environment variables
# For maintainers: build-time OAuth2 client IDs for testnet/mainnet.
# End users installing pre-built binaries do not need to configure this file.
#
# Legacy XION_* names are accepted as fallback (deprecated); prefer VERONA_*.

# Testnet OAuth2 client ID
VERONA_TESTNET_OAUTH_CLIENT_ID=GhA--1KkKJYAH5H4 # For testnet
# VERONA_TESTNET_OAUTH_CLIENT_ID=upAWDXvkmtCU5RVB # For testnet (local development)
# Legacy fallback: XION_TESTNET_OAUTH_CLIENT_ID

# Testnet OAuth API URL override (for local oauth2-api-service development)
# Uncomment to point toolkit at a locally running oauth2-api-service:
# VERONA_TESTNET_OAUTH_API_URL=http://localhost:8787
# Legacy fallback: XION_TESTNET_OAUTH_API_URL

# Mainnet OAuth2 client ID (required for local builds targeting mainnet)
VERONA_MAINNET_OAUTH_CLIENT_ID=i0mkCvsHcqgMI_6k
# Legacy fallback: XION_MAINNET_OAUTH_CLIENT_ID

# Mainnet OAuth API URL override (optional; default: https://oauth2.burnt.com)
# VERONA_MAINNET_OAUTH_API_URL=https://oauth2.burnt.com
# Legacy fallback: XION_MAINNET_OAUTH_API_URL

# Override active network at runtime (testnet | mainnet)
# VERONA_NETWORK_OVERRIDE=testnet
# Legacy fallback: XION_NETWORK_OVERRIDE

# Custom skills directory (overrides bundled skills path)
# VERONA_SKILLS_DIR=/path/to/skills
# Legacy fallback: XION_SKILLS_DIR

# ============================================================================
# CI/CD Testing (Optional — NOT needed for local development)
# ============================================================================

# Encryption key for credential storage in CI environments.
# Local development uses automatic machine ID derivation — no configuration needed.
# Only set this if you are running tests in CI/CD where machine ID is unstable.
#
# Format: 64 hex characters (32 bytes)
# Generate with: openssl rand -hex 32
#
# Example (DO NOT use in production):
# VERONA_CI_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Legacy fallback: XION_CI_ENCRYPTION_KEY

# ============================================================================
# Skill / script runtime (Optional)
# ============================================================================

# Enable audit logging in treasury skill scripts (default: true)
# VERONA_AUDIT_LOG=true
# Legacy fallback: XION_AUDIT_LOG

# Audit log file path (default: ~/.verona-toolkit/audit.log)
# VERONA_AUDIT_LOG_FILE=~/.verona-toolkit/audit.log
# Legacy fallback: XION_AUDIT_LOG_FILE

# Skip confirmation prompts in skill scripts (useful for CI/CD)
# VERONA_SKIP_CONFIRM=true
# Legacy fallback: XION_SKIP_CONFIRM
